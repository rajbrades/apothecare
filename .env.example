# ===========================================
# APOTHECARE - Environment Variables
# ===========================================
# Copy this to .env.local and fill in your values.
#
# PRODUCTION (Vercel):
#   Set all variables in the Vercel project dashboard under Settings → Environment Variables.
#   NEXT_PUBLIC_APP_URL must be set to https://apothecare.ai in production.
#
# SUPABASE AUTH REDIRECT URLS:
#   In Supabase Dashboard → Authentication → URL Configuration, set:
#     Site URL:       https://apothecare.ai
#     Redirect URLs:
#       https://apothecare.ai/auth/callback
#       https://apothecare.ai/auth/callback?*
#       https://apothecare.vercel.app/auth/callback
#       https://apothecare.vercel.app/auth/callback?*
#       http://localhost:3000/auth/callback
#       http://localhost:3000/auth/callback?*

# Supabase
# Local dev: use your local Supabase project URL (http://localhost:54321)
# Production: use your hosted Supabase project URL (https://<ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-webhook-secret
STRIPE_PRICE_ID_PRO=your-pro-price-id

# App
# Local:      http://localhost:3000
# Production: https://apothecare.ai
NEXT_PUBLIC_APP_URL=https://apothecare.ai
NEXT_PUBLIC_APP_NAME=Apothecare

# Optional: Site-wide password gate (leave unset to disable)
# SITE_PASSWORD=your-site-password

# Database (for direct psql migrations — local dev only)
DATABASE_URL=postgresql://postgres:postgres@localhost:54321/postgres
